# ===========================================
# Nuxt 4 Layers Template - Environment Variables
# ===========================================
# Copie este arquivo para .env e configure os valores
#
# Nuxt usa prefixo NUXT_ para override automático do runtimeConfig:
#   NUXT_<KEY>              → runtimeConfig.<key>        (server-only)
#   NUXT_PUBLIC_<KEY>       → runtimeConfig.public.<key> (client + server)

# API externa (server-only — nunca exposto ao client)
# NUXT_API_EXTERNAL_BASE_URL=https://api.example.com

# API pública (client + server)
# NUXT_PUBLIC_API_BASE_URL=/api

# SEO (@nuxtjs/seo)
# NUXT_SITE_URL=https://meusite.com
# NUXT_SITE_INDEXABLE=true
