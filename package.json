{
  "name": "nuxt-template",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "nuxt typecheck",
    "quality": "npm run typecheck && npm run lint && npm run format:check",
    "quality:fix": "npm run lint:fix && npm run format",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:nuxt": "vitest run --project nuxt",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install --with-deps",
    "prepare": "husky",
    "setup": "npx husky init && echo 'npx lint-staged' > .husky/pre-commit && echo 'npx --no -- commitlint --edit \"$1\"' > .husky/commit-msg && echo 'Git hooks configurados!'",
    "docs:llms": "node scripts/generate-llms-full.mjs"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write",
      "bash scripts/check-patterns.sh"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/seo": "^5.1.0",
    "@pinia/nuxt": "^0.11.3",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.562.0",
    "nuxt": "^4.1.3",
    "nuxt-security": "^2.5.1",
    "pinia-plugin-persistedstate": "^4.7.1",
    "reka-ui": "^2.9.2",
    "shadcn-nuxt": "^2.5.1",
    "tailwind-merge": "^3.4.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vue-sonner": "^2.0.9",
    "zod": "^3.25.76"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "unhead": "^2.1.12",
    "lodash-es": "^4.18.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@nuxt/eslint": "^1.4.1",
    "@nuxt/test-utils": "^3.23.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.27.0",
    "happy-dom": "^20.3.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
